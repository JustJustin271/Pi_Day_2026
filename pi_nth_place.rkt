;; pi-digit : num or string -> string
;; Takes in a digits place of pi and outputs the nth digit in pi
;; Or takes in joke answers of strings like "pie" and outputs funny response
;; Starts at one, not 0 :)
;; So the 1st digit of pi is 3, not 1 :))
(define (pi-digit nth)
  (cond
    [(and (integer? nth) (<= nth 1024) (>= nth 1)) (string-ith pi-1024 (- nth 1))]
    [(integer? nth) "Digit place not available in system"]
    [(and (number? nth)(= nth pi)) "Good luck trying to find the pi-th digit in pi :)"]
    [(string=? "pie" nth) "Wrong kind of pie :)"]
    [else "Invalid input"]))

(check-expect (pi-digit 1) "3")
(check-expect (pi-digit 1024) "8")
(check-expect (pi-digit 1025) "Digit place not available in system")
(check-expect (pi-digit pi) "Good luck trying to find the pi-th digit in pi :)")
(check-expect (pi-digit "pie") "Wrong kind of pie :)")
(check-expect (pi-digit "apple") "Invalid input")

